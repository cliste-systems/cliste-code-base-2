# TTS: elevenlabs | openai | deepgram. For the ElevenLabs receptionist voice, set ELEVENLABS_API_KEY and e.g.:
# SALON_TTS_PROVIDER=elevenlabs
# If SALON_TTS_PROVIDER=deepgram but ELEVENLABS_API_KEY is set, the worker prefers ElevenLabs unless
# SALON_TTS_FORCE_DEEPGRAM=1 (Deepgram STT stays on SALON_STT_PROVIDER=deepgram).
# SALON_TTS_PROVIDER=openai
# OpenAI speech (when SALON_TTS_PROVIDER=openai). Voice names: alloy, ash, ballad, coral, echo, fable, nova, onyx, sage, shimmer
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=coral
# OPENAI_TTS_SPEED=1
# OPENAI_TTS_INSTRUCTIONS=

# LIVEKIT_URL=wss://….livekit.cloud
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Worker name for explicit dispatch (default cliste-salon-node). Empty = try automatic dispatch only.
LIVEKIT_AGENT_NAME=cliste-salon-node

# DEFAULT_SALON_PHONE=+353749389378
# DEFAULT_SALON_SLUG=admin-salon

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# SALON_TIMEZONE=Europe/Dublin

# STT: default flux-general (reliable on SIP). For Cloud parity: deepgram/nova-3:en
# LIVEKIT_INFERENCE_STT_MODEL=deepgram/flux-general
# LIVEKIT_INFERENCE_STT_LANGUAGE=en
# LIVEKIT_INFERENCE_LLM_MODEL=openai/gpt-4o-mini
# Stronger (costlier) voice agent: LIVEKIT_INFERENCE_LLM_MODEL=openai/gpt-4o
# LIVEKIT_ENDPOINTING_MIN_MS=280
# LIVEKIT_ENDPOINTING_MAX_MS=2200
# Deepgram STT silence window (ms) before end-of-utterance; short words need ~100–150.
# LIVEKIT_STT_ENDPOINTING_MS=120

# Required for worker when SALON_TTS_PROVIDER is unset/elevenlabs (or omit OPENAI path).
ELEVENLABS_API_KEY=
# ELEVEN_VOICE_ID=C92s6vssSLlabgIln1iY
# eleven_flash_v2_5 (~75ms inference) is the recommended real-time agent
# model — replaces the slower turbo_v2_5. Turbo had a tail-streaming
# artefact that made short "goodbye!" lines sound like a drawn-out "aaaaa".
# ELEVEN_TTS_MODEL=eleven_flash_v2_5
# ELEVEN_STREAMING_LATENCY=4
# Flash defaults tuned for Irish receptionist tone (turbo used 0.48 / 0.35).
# ELEVEN_VOICE_STABILITY=0.55
# ELEVEN_VOICE_SIMILARITY=0.80
# ELEVEN_VOICE_STYLE=0.25

SUPABASE_PUBLISHABLE_KEY=
# Required for OpenAI TTS when SALON_TTS_PROVIDER=openai; also used for menu intent + postprocess.
OPENAI_API_KEY=
# Optional: separate key for matchServiceFromUtterance intent step (defaults to OPENAI_API_KEY).
# SERVICE_INTENT_OPENAI_KEY=
# SERVICE_INTENT_MODEL=gpt-4o-mini
DEEPGRAM_API_KEY=

# Optional: comma-separated STT keyterms per salon (e.g. stylist names). Menu names are added automatically.
# LIVEKIT_STT_EXTRA_KEYTERMS=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# SMS-capable sender for booking-link + automatic booking confirmations after bookAppointment.
# TWILIO_SMS_FROM=
# LiveKit browser / mock participants have no real phone — set your mobile (E.164) so confirmation SMS still fires in dev.
# CLISTE_FALLBACK_CONFIRMATION_SMS_TO=+353871234567

# --- GDPR / data minimisation ---
# Set to "off" only if your salon plays a separate IVR notice before the call
# reaches the AI. Default ("on") makes the agent state out loud that they are
# an AI assistant and the call is processed for the booking.
# CLISTE_AI_DISCLOSURE_OPENING=on
# Override the exact disclosure sentence (kept short and human).
# CLISTE_AI_DISCLOSURE_TEXT=Just so you know, I'm an AI assistant for the salon and your call is processed to help with your booking.
# How long verbatim transcripts are kept on call_logs (used by the
# scripts/gdpr-purge-transcripts.ts cron). Defaults to 30 days.
# CLISTE_TRANSCRIPT_RETENTION_DAYS=30

# --- Speed knobs ---
# How long to in-process cache the salon config + services menu (ms).
# Dashboard edits surface within this window. Default 60s.
# CLISTE_SALON_CACHE_TTL_MS=60000
# Endpointing (ms) — how long after a caller stops speaking we treat the turn
# as complete. The turn-detector EOU model adapts dynamically between min/max;
# fixed mode pins at minDelay. Defaults: 200 / 2500, mode=dynamic.
# LIVEKIT_ENDPOINTING_MIN_MS=200
# LIVEKIT_ENDPOINTING_MAX_MS=2500
# LIVEKIT_ENDPOINTING_MODE=dynamic
# LiveKit EOU turn-detector model (open-weights transformer, ~500MB RAM).
# Downloads once on first call; cached in ~/.cache/huggingface on the worker.
# Set to "off" to fall back to STT (Deepgram) or VAD end-of-speech.
# LIVEKIT_USE_TURN_DETECTOR=on
# LLM settings — lower temperature = less waffle = shorter replies = faster TTS.
# LIVEKIT_LLM_TEMPERATURE=0.45
# LIVEKIT_LLM_MAX_TOKENS=220

# --- Stripe (pay-by-SMS-link from the voice agent) ---
# MUST be the SAME platform secret key as cliste-code-base-1's Vercel deploy
# (sandbox key in dev, live key in prod). If this is unset on Railway, the
# voice agent will NOT offer "pay online" at all — it quietly drops the
# pay-online branch in the prompt and hides the sendPaymentLink tool, so
# the agent never apologises on-call that "online payment isn't configured".
STRIPE_SECRET_KEY=
# Cliste's cut per paid booking, in basis points (500 = 5.00%). Must match the
# web app so totals/fees agree. Leave unset to use the 5% default.
# CLISTE_STRIPE_APPLICATION_FEE_BPS=500
# Lowercase ISO-4217. Defaults to eur.
# CLISTE_STRIPE_CURRENCY=eur
# Public salon storefront URL (cliste-code-base-1) so Stripe success_url lands
# the customer on the branded /<salonSlug>/booking/success page.
# CLISTE_BOOKING_SITE_URL=https://book.clistesystems.ie

# --- Estimated call cost (USD) for admin / call_logs.cost_estimate — tune to match invoices ---
# LiveKit agent/participant minutes (https://livekit.io/pricing)
# CALL_COST_LIVEKIT_USD_PER_MIN=0.01
# STT via Inference (set USD/min or fraction to 0 if bundled in LiveKit)
# CALL_COST_STT_BILLED_FRACTION_OF_WALL=0.5
# CALL_COST_STT_USD_PER_MIN=0.006
# LLM: token heuristic OR flat $/min (if flat is set, it replaces token math)
# CALL_COST_LLM_INPUT_TOKENS_PER_MIN=1400
# CALL_COST_LLM_OUTPUT_TOKENS_PER_MIN=450
# CALL_COST_LLM_INPUT_USD_PER_1M_TOKENS=0.15
# CALL_COST_LLM_OUTPUT_USD_PER_1M_TOKENS=0.6
# CALL_COST_LLM_USD_PER_MIN_FLAT=
# ElevenLabs TTS: default flat $/min (matches ~0.13/min ballpark for many voice setups).
# Set to 0 to use per-character model: CALL_COST_TTS_CHARS_PER_MIN × CALL_COST_TTS_USD_PER_1K_CHARS
# CALL_COST_TTS_USD_PER_MIN=0.13
# CALL_COST_TTS_CHARS_PER_MIN=220
# CALL_COST_TTS_USD_PER_1K_CHARS=0.12
# Twilio SIP + SMS (SMS count is measured per successful send on the call)
# CALL_COST_TWILIO_VOICE_USD_PER_MIN=0.009
# CALL_COST_TWILIO_SMS_USD_EACH=0.008
# CALL_COST_SUPABASE_USD_PER_CALL=0.00002
# Post-call transcript LLM (call_postprocess)
# CALL_COST_POSTPROCESS_BASE_USD=0.0004
# CALL_COST_POSTPROCESS_USD_PER_1K_TRANSCRIPT_CHARS=0.00008
# CALL_COST_POSTPROCESS_CHAR_CAP=50000
# Daily cost report: npx tsx scripts/report-daily-costs.ts
# REPORT_COST_DAYS=14
