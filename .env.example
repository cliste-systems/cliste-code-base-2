# LIVEKIT_URL=wss://….livekit.cloud
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Worker name for explicit dispatch (default cliste-salon-node). Empty = try automatic dispatch only.
LIVEKIT_AGENT_NAME=cliste-salon-node

# DEFAULT_SALON_PHONE=+353749389378
# DEFAULT_SALON_SLUG=admin-salon

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# SALON_TIMEZONE=Europe/Dublin

# STT: default flux-general (reliable on SIP). For Cloud parity: deepgram/nova-3:en
# LIVEKIT_INFERENCE_STT_MODEL=deepgram/flux-general
# LIVEKIT_INFERENCE_STT_LANGUAGE=en
# LIVEKIT_INFERENCE_LLM_MODEL=openai/gpt-4o-mini
# LIVEKIT_ENDPOINTING_MIN_MS=280
# LIVEKIT_ENDPOINTING_MAX_MS=2200
# Deepgram STT silence window (ms) before end-of-utterance; short words need ~100–150.
# LIVEKIT_STT_ENDPOINTING_MS=120

ELEVENLABS_API_KEY=
# ELEVEN_VOICE_ID=C92s6vssSLlabgIln1iY
# ELEVEN_TTS_MODEL=eleven_turbo_v2_5
# ELEVEN_STREAMING_LATENCY=4
# ELEVEN_VOICE_STABILITY=0.48
# ELEVEN_VOICE_SIMILARITY=0.82
# ELEVEN_VOICE_STYLE=0.35

SUPABASE_PUBLISHABLE_KEY=
OPENAI_API_KEY=
# Optional: separate key for matchServiceFromUtterance intent step (defaults to OPENAI_API_KEY).
# SERVICE_INTENT_OPENAI_KEY=
# SERVICE_INTENT_MODEL=gpt-4o-mini
DEEPGRAM_API_KEY=

# Optional: comma-separated STT keyterms per salon (e.g. stylist names). Menu names are added automatically.
# LIVEKIT_STT_EXTRA_KEYTERMS=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# SMS-capable sender for booking-link + automatic booking confirmations after bookAppointment.
# TWILIO_SMS_FROM=

# --- Estimated call cost (USD) for admin / call_logs.cost_estimate — tune to match invoices ---
# LiveKit agent/participant minutes (https://livekit.io/pricing)
# CALL_COST_LIVEKIT_USD_PER_MIN=0.01
# STT via Inference (set USD/min or fraction to 0 if bundled in LiveKit)
# CALL_COST_STT_BILLED_FRACTION_OF_WALL=0.5
# CALL_COST_STT_USD_PER_MIN=0.006
# LLM: token heuristic OR flat $/min (if flat is set, it replaces token math)
# CALL_COST_LLM_INPUT_TOKENS_PER_MIN=1400
# CALL_COST_LLM_OUTPUT_TOKENS_PER_MIN=450
# CALL_COST_LLM_INPUT_USD_PER_1M_TOKENS=0.15
# CALL_COST_LLM_OUTPUT_USD_PER_1M_TOKENS=0.6
# CALL_COST_LLM_USD_PER_MIN_FLAT=
# ElevenLabs TTS: default flat $/min (matches ~0.13/min ballpark for many voice setups).
# Set to 0 to use per-character model: CALL_COST_TTS_CHARS_PER_MIN × CALL_COST_TTS_USD_PER_1K_CHARS
# CALL_COST_TTS_USD_PER_MIN=0.13
# CALL_COST_TTS_CHARS_PER_MIN=220
# CALL_COST_TTS_USD_PER_1K_CHARS=0.12
# Twilio SIP + SMS (SMS count is measured per successful send on the call)
# CALL_COST_TWILIO_VOICE_USD_PER_MIN=0.009
# CALL_COST_TWILIO_SMS_USD_EACH=0.008
# CALL_COST_SUPABASE_USD_PER_CALL=0.00002
# Post-call transcript LLM (call_postprocess)
# CALL_COST_POSTPROCESS_BASE_USD=0.0004
# CALL_COST_POSTPROCESS_USD_PER_1K_TRANSCRIPT_CHARS=0.00008
# CALL_COST_POSTPROCESS_CHAR_CAP=50000
# Daily cost report: npx tsx scripts/report-daily-costs.ts
# REPORT_COST_DAYS=14
